# NOMINATIM_URL=http://localhost:8080/search
# Autoaddress.com API key for background eircode enrichment (optional)
# AUTOADDRESS_KEY=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
