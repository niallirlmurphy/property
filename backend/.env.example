# Copy to .env and fill in values
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Optional: Sentry DSN for error tracking and performance monitoring
# SENTRY_DSN=https://xxxxxxxx@o000000.ingest.sentry.io/0000000

# Optional: point to a self-hosted Nominatim instead of the public OSM instance
# NOMINATIM_URL=http://localhost:8080/search

# Autoaddress.com API key for background eircode enrichment (optional)
# AUTOADDRESS_KEY=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
